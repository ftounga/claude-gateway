<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
            http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.27.xsd">

    <!--
      pgvector : Postgres uniquement. Active l'extension, ajoute la colonne d'embedding
      sur chunks et crée l'index ivfflat. Dimension 1536 (embeddings via API fournisseur) —
      à ajuster si migration vers un modèle local (ex. all-MiniLM = 384). Voir OPEN_QUESTIONS.
    -->
    <changeSet id="002-enable-pgvector" author="claude-gateway" dbms="postgresql">
        <sql>CREATE EXTENSION IF NOT EXISTS vector;</sql>
    </changeSet>

    <changeSet id="002-chunks-embedding-column" author="claude-gateway" dbms="postgresql">
        <sql>ALTER TABLE chunks ADD COLUMN embedding vector(1536);</sql>
    </changeSet>

    <changeSet id="002-chunks-embedding-index" author="claude-gateway" dbms="postgresql">
        <sql>CREATE INDEX IF NOT EXISTS chunks_embedding_idx
             ON chunks USING ivfflat (embedding vector_l2_ops) WITH (lists = 100);</sql>
    </changeSet>

</databaseChangeLog>
