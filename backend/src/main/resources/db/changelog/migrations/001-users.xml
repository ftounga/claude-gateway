<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
            http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.27.xsd">

    <!--
      Table `users` (SF-01-01). Racine de l'isolation multi-tenant (user_id = users.id).
      Type `uuid` et `timestamp with time zone` dépendent du SGBD : un changeset Postgres
      (staging/prod) et un changeset H2 (dev/tests) en parallèle, comme le schéma initial.
      L'identifiant est généré côté application (Hibernate @UuidGenerator) — pas de default DB requis.
    -->

    <!-- ============================ POSTGRESQL ============================ -->
    <changeSet id="001-users-postgresql" author="claude-gateway" dbms="postgresql">
        <createTable tableName="users">
            <column name="id" type="uuid">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="email" type="varchar(320)">
                <constraints nullable="false" unique="true" uniqueConstraintName="uk_users_email"/>
            </column>
            <column name="password_hash" type="varchar(255)"/>
            <column name="email_verified" type="boolean" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
            <column name="provider" type="varchar(16)">
                <constraints nullable="false"/>
            </column>
            <column name="role" type="varchar(16)" defaultValue="USER">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="timestamptz" defaultValueComputed="now()">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="timestamptz" defaultValueComputed="now()">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

    <!-- ================================ H2 ================================ -->
    <changeSet id="001-users-h2" author="claude-gateway" dbms="h2">
        <createTable tableName="users">
            <column name="id" type="uuid">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="email" type="varchar(320)">
                <constraints nullable="false" unique="true" uniqueConstraintName="uk_users_email"/>
            </column>
            <column name="password_hash" type="varchar(255)"/>
            <column name="email_verified" type="boolean" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
            <column name="provider" type="varchar(16)">
                <constraints nullable="false"/>
            </column>
            <column name="role" type="varchar(16)" defaultValue="USER">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="timestamp with time zone" defaultValueComputed="now()">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="timestamp with time zone" defaultValueComputed="now()">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

</databaseChangeLog>
