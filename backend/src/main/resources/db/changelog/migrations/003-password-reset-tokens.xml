<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
            http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.27.xsd">

    <!--
      Table `password_reset_tokens` (SF-01-04). Token à usage unique et expirant (1h), rattaché
      à un utilisateur (user_id -> users.id). Un changeset Postgres et un changeset H2 en
      parallèle, comme 001/002. Identifiant généré côté application (Hibernate @UuidGenerator).
    -->

    <!-- ============================ POSTGRESQL ============================ -->
    <changeSet id="003-password-reset-tokens-postgresql" author="claude-gateway" dbms="postgresql">
        <createTable tableName="password_reset_tokens">
            <column name="id" type="uuid">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="user_id" type="uuid">
                <constraints nullable="false" foreignKeyName="fk_password_reset_user"
                             references="users(id)" deleteCascade="true"/>
            </column>
            <column name="token" type="varchar(255)">
                <constraints nullable="false" unique="true" uniqueConstraintName="uk_password_reset_token"/>
            </column>
            <column name="expires_at" type="timestamptz">
                <constraints nullable="false"/>
            </column>
            <column name="used_at" type="timestamptz"/>
            <column name="created_at" type="timestamptz" defaultValueComputed="now()">
                <constraints nullable="false"/>
            </column>
        </createTable>
        <createIndex tableName="password_reset_tokens" indexName="idx_password_reset_user_id">
            <column name="user_id"/>
        </createIndex>
    </changeSet>

    <!-- ================================ H2 ================================ -->
    <changeSet id="003-password-reset-tokens-h2" author="claude-gateway" dbms="h2">
        <createTable tableName="password_reset_tokens">
            <column name="id" type="uuid">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="user_id" type="uuid">
                <constraints nullable="false" foreignKeyName="fk_password_reset_user"
                             references="users(id)" deleteCascade="true"/>
            </column>
            <column name="token" type="varchar(255)">
                <constraints nullable="false" unique="true" uniqueConstraintName="uk_password_reset_token"/>
            </column>
            <column name="expires_at" type="timestamp with time zone">
                <constraints nullable="false"/>
            </column>
            <column name="used_at" type="timestamp with time zone"/>
            <column name="created_at" type="timestamp with time zone" defaultValueComputed="now()">
                <constraints nullable="false"/>
            </column>
        </createTable>
        <createIndex tableName="password_reset_tokens" indexName="idx_password_reset_user_id">
            <column name="user_id"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>
