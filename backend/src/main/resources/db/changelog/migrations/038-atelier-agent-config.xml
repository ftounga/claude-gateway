<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
            http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.27.xsd">

    <!--
      SF-28-08 — Fondation Managed Agents (F-28 / Phase 2, ADR-013). Configuration globale à la
      plateforme (un environment/agent partagés provisionnés une seule fois puis réutilisés). Pas de
      `user_id` : l'isolation par utilisateur se fait sur la session (SF-28-09). Changesets Postgres
      et H2 en parallèle. Réversible.
    -->

    <!-- ============================ POSTGRESQL ============================ -->
    <changeSet id="038-atelier-agent-config-postgresql" author="claude-gateway" dbms="postgresql">
        <createTable tableName="atelier_agent_config">
            <column name="id" type="uuid"><constraints primaryKey="true" nullable="false"/></column>
            <column name="environment_id" type="varchar(255)"><constraints nullable="false"/></column>
            <column name="agent_id" type="varchar(255)"><constraints nullable="false"/></column>
            <column name="agent_version" type="varchar(255)"><constraints nullable="false"/></column>
            <column name="created_at" type="timestamptz" defaultValueComputed="now()">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

    <!-- ================================ H2 ================================ -->
    <changeSet id="038-atelier-agent-config-h2" author="claude-gateway" dbms="h2">
        <createTable tableName="atelier_agent_config">
            <column name="id" type="uuid"><constraints primaryKey="true" nullable="false"/></column>
            <column name="environment_id" type="varchar(255)"><constraints nullable="false"/></column>
            <column name="agent_id" type="varchar(255)"><constraints nullable="false"/></column>
            <column name="agent_version" type="varchar(255)"><constraints nullable="false"/></column>
            <column name="created_at" type="timestamp with time zone" defaultValueComputed="now()">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

</databaseChangeLog>
