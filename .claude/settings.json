{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/guard-governance.sh\"",
            "timeout": 10,
            "statusMessage": "Garde-fou gouvernance (push --force / merge --squash)"
          }
        ]
      }
    ]
  }
}
